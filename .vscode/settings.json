{
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "eslint.workingDirectories": [
    { "directory": "./backend/auth", "changeProcessCWD": true },
    { "directory": "./backend/core", "changeProcessCWD": true },
    { "directory": "./backend/game", "changeProcessCWD": true },
    { "directory": "./backend/gateway", "changeProcessCWD": true },
    { "directory": "./frontend", "changeProcessCWD": true }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.runtime": "node",
  "eslint.useFlatConfig": true,
  "eslint.execArgv": [
    "--max-old-space-size=4096"
  ],
  "eslint.run": "onSave"
}
